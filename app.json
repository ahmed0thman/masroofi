{
  "expo": {
    "name": "masroofi",
    "slug": "masroofi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "masroofi",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.ahmed0thman.masroofi"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#004c3f",
        "foregroundImage": "./assets/images/Icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ahmed0thman.masroofi"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#004c3f",
          "android": {
            "image": "./assets/images/logo.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/cairo/Cairo-ExtraLight.ttf",
            "./assets/fonts/cairo/Cairo-Regular.ttf",
            "./assets/fonts/cairo/Cairo-Light.ttf",
            "./assets/fonts/cairo/Cairo-Medium.ttf",
            "./assets/fonts/cairo/Cairo-SemiBold.ttf",
            "./assets/fonts/cairo/Cairo-Bold.ttf",
            "./assets/fonts/cairo/Cairo-ExtraBold.ttf"
          ]
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
          "playback": true,
          "recording": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
